# ── IA Provider ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase — Base de Órdenes (maintenance DB) ──────────────────────
ORDERS_SUPABASE_URL=https://<proyecto>.supabase.co
ORDERS_SUPABASE_KEY=<anon-key>
ORDERS_SUPABASE_SERVICE_KEY=<service-role-key>

# ── Supabase — Base de Cotizaciones (clients/quotes DB) ──────────────
QUOTES_SUPABASE_URL=https://<proyecto>.supabase.co
QUOTES_SUPABASE_KEY=<anon-key>
QUOTES_SUPABASE_SERVICE_KEY=<service-role-key>

# ── Servidor ──────────────────────────────────────────────────────────
PORT=3000

# ── WhatsApp / Twilio (opcional) ──────────────────────────────────────
# Si estas variables no están presentes, el canal WhatsApp se desactiva.
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
