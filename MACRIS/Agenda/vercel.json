{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "redirects": [
    {
      "source": "/",
      "destination": "/apps/agenda",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/apps/agenda/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/apps/agenda/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/apps/agenda",
      "destination": "/index.html"
    }
  ]
}
