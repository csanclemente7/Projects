<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Cache interno -->
    <cache-path
        name="images_cache"
        path="." />

    <!-- Cache externo (recomendado por Capacitor para Camera) -->
    <external-cache-path
        name="images_external_cache"
        path="." />

    <!-- Directorio interno de archivos -->
    <files-path
        name="images_files"
        path="." />

    <!-- Directorio externo privado de la app -->
    <external-files-path
        name="images_external_files"
        path="Pictures/" />

</paths>
